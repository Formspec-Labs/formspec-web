{
  "name": "formspec-web",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./adapter-conformance": "./src/adapter-conformance/index.ts",
    "./adapters/http": "./src/adapters/http/index.ts",
    "./adapters/identity": "./src/adapters/identity/index.ts",
    "./composition": "./src/composition/index.ts",
    "./config": "./src/config/index.ts",
    "./ports": "./src/ports/index.ts",
    "./shared": "./src/shared/index.ts",
    "./profiles": "./src/profiles/index.ts"
  },
  "license": "Apache-2.0",
  "description": "Public reference UI for Formspec — respondent renderer (MVP) + verifier (post-MVP) + selective-proof viewer (post-MVP). Hexagonal architecture per web ADR-0009.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "check:vendor-leaks": "scripts/check-vendor-leaks.sh",
    "check:upstream-theme": "node scripts/check-upstream-theme-assets.mjs",
    "ci": "npm run typecheck && npm run lint && npm test && npm run check:vendor-leaks && npm run check:upstream-theme && npm run test:e2e && npm run build"
  },
  "dependencies": {
    "@formspec-org/engine": "file:vendor/formspec-engine",
    "@formspec-org/types": "file:vendor/formspec-types",
    "oidc-client-ts": "^3.5.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^9.18.0",
    "@playwright/test": "^1.60.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "eslint": "^9.18.0",
    "eslint-import-resolver-typescript": "^3.7.0",
    "eslint-plugin-import": "^2.31.0",
    "happy-dom": "^20.9.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.20.0",
    "vite": "^7.0.0",
    "vitest": "^4.0.0"
  }
}
