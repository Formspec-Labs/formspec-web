{
  "name": "default-on-instance-unavailable",
  "description": "org default-on; instance unavailable; form silent -> disabled with default-on-no-instance",
  "mode": "production",
  "instance": {
    "respondentPlace": "unavailable",
    "status": "available",
    "documentPresentation": "unavailable",
    "fileUpload": "unavailable",
    "crossIssuerHistory": "unavailable"
  },
  "org": {
    "features": {
      "respondentPlace": "default-on",
      "fileUpload": "allowed",
      "crossIssuerHistory": "allowed"
    }
  },
  "form": {
    "features": {}
  },
  "expect": {
    "kind": "profile",
    "enabled": [],
    "disabled": {
      "respondentPlace": "default-on-no-instance",
      "status": "not-requested",
      "fileUpload": "not-requested",
      "crossIssuerHistory": "not-requested"
    }
  }
}
