{
  "name": "form-forbidden-org-required",
  "description": "form forbids status; org requires it -> FeaturePolicyConflict",
  "mode": "production",
  "instance": {
    "respondentPlace": "available",
    "status": "available",
    "documentPresentation": "unavailable",
    "fileUpload": "unavailable",
    "crossIssuerHistory": "unavailable",
    "offlineSubmit": "unavailable",
    "payment": "unavailable",
    "embed": "unavailable"
  },
  "org": {
    "features": {
      "status": "required",
      "fileUpload": "allowed",
      "crossIssuerHistory": "allowed",
      "offlineSubmit": "allowed",
      "payment": "allowed",
      "embed": "allowed"
    }
  },
  "form": {
    "features": {
      "status": "forbidden"
    }
  },
  "expect": {
    "kind": "throws",
    "code": "FeaturePolicyConflict"
  }
}
